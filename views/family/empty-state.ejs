<%
  const personalStats = typeof personalWorkspaceStats !== 'undefined' && personalWorkspaceStats ? personalWorkspaceStats : { total: 0 };
  const hasPersonalData = Number(personalStats.total || 0) > 0;
%>

<div class="row g-4 align-items-stretch">
  <div class="col-lg-8">
    <div class="card family-card family-empty-card h-100">
      <div class="card-body">
        <div class="family-section-header family-empty-header">
          <div>
            <p class="section-label">Personal workspace</p>
            <h2>You are using My Budget alone</h2>
          </div>
          <span class="family-personal-badge">Single user</span>
        </div>

        <p class="family-description mb-4">
          Your categories, transactions, wishlist and calendar are private while you are not part of a family. Create a family when you are ready to share one common budget workspace with other registered users.
        </p>

        <div class="family-personal-summary-grid mb-4">
          <div class="family-personal-summary-item">
            <span>Categories</span>
            <strong><%= personalStats.categories || 0 %></strong>
          </div>
          <div class="family-personal-summary-item">
            <span>Transactions</span>
            <strong><%= personalStats.transactions || 0 %></strong>
          </div>
          <div class="family-personal-summary-item">
            <span>Wishlist</span>
            <strong><%= personalStats['wishlist items'] || 0 %></strong>
          </div>
          <div class="family-personal-summary-item">
            <span>Calendar</span>
            <strong><%= personalStats['calendar events'] || 0 %></strong>
          </div>
        </div>

        <div class="family-info-box mb-4">
          <i class="bi bi-info-circle"></i>
          <div>
            <strong>What happens when you create a family?</strong>
            <p>
              Your current personal data will be moved into the new shared family workspace. After that, all family members will use the same categories, transactions, wishlist and calendar.
            </p>
          </div>
        </div>

        <button class="btn btn-primary rounded-pill px-4" type="button" data-bs-toggle="modal" data-bs-target="#createFamilyModal">
          Create family
        </button>
      </div>
    </div>
  </div>

  <aside class="col-lg-4">
    <div class="card family-card family-access-card h-100">
      <div class="card-body">
        <div class="family-section-header">
          <div>
            <p class="section-label">How it works</p>
            <h2>Workspace rules</h2>
          </div>
        </div>

        <div class="family-rules-list">
          <div class="family-rule-item">
            <strong>Personal mode</strong>
            <p>Only you can see and edit your own budget data.</p>
          </div>
          <div class="family-rule-item">
            <strong>Create family</strong>
            <p>Your existing personal data becomes the first shared family budget.</p>
          </div>
          <div class="family-rule-item">
            <strong>Family mode</strong>
            <p>All new budget data belongs to the family workspace, not to one user.</p>
          </div>
        </div>
      </div>
    </div>
  </aside>
</div>

<div class="modal fade" id="createFamilyModal" tabindex="-1" aria-labelledby="createFamilyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content family-modal-content">
      <div class="modal-header border-0 pb-0">
        <div>
          <p class="section-label mb-1">Create workspace</p>
          <h2 class="modal-title family-modal-title" id="createFamilyModalLabel">Create family workspace</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <form action="/family/create" method="POST" class="family-preserve-scroll-form">
        <div class="modal-body pt-3">
          <div class="family-warning-box mb-3">
            <i class="bi bi-arrow-left-right"></i>
            <div>
              <strong>Your personal data will be moved</strong>
              <p>
                <% if (hasPersonalData) { %>
                  You currently have <%= personalStats.total %> personal records. They will become shared family records after the family is created.
                <% } else { %>
                  You do not have personal records yet. The new family workspace will start empty.
                <% } %>
              </p>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="familyName">Family name</label>
            <input class="form-control rounded-pill" id="familyName" name="familyName" type="text" placeholder="Enter family name" required />
          </div>

          <label class="family-checkbox-confirm">
            <input type="checkbox" required>
            <span>I understand that my personal budget data will become shared family data.</span>
          </label>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-primary rounded-pill px-4" type="submit">Create family</button>
        </div>
      </form>
    </div>
  </div>
</div>
