<%- include('../partials/header') %>

<%
  const pageFilters = typeof filters !== 'undefined' ? filters : {};
  const pageFolders = (typeof folders !== 'undefined' && Array.isArray(folders)) ? folders : [];
  const pageFolderCards = (typeof folderCards !== 'undefined' && Array.isArray(folderCards)) ? folderCards : pageFolders.map((folder) => ({ name: folder, user_id: 0, owner_name: '' }));
  const pageFolderStats = typeof folderStats !== 'undefined' ? folderStats : {};
  const pageWishlistItems = (typeof wishlistItems !== 'undefined' && Array.isArray(wishlistItems)) ? wishlistItems : [];
  const pageAllWishlistItems = (typeof allWishlistItems !== 'undefined' && Array.isArray(allWishlistItems)) ? allWishlistItems : [];
  const pageSummary = typeof summary !== 'undefined' ? summary : {
    balance: 0,
    plannedTotal: 0,
    postponedTotal: 0,
    boughtTotal: 0,
    balanceAfterPlans: 0,
    totalItems: 0
  };
  const pageErrorMessage = typeof errorMessage !== 'undefined' ? errorMessage : null;
  const pageSuccessMessage = typeof successMessage !== 'undefined' ? successMessage : null;

  const pageFamilyMembers = (typeof familyMembers !== 'undefined' && Array.isArray(familyMembers)) ? familyMembers : [];
  const pageCurrentUser = typeof currentUser !== 'undefined' ? currentUser : null;

  const formatMoney = (value) => `${Number(value || 0).toFixed(2)} €`;
  const activeStatus = pageFilters.status || 'all';
  const activeFolder = pageFilters.folder || 'all';
  const activeSort = pageFilters.sort || 'newest';
  const activeBuyer = pageFilters.buyer || 'all';
  const searchQuery = pageFilters.q || '';
  const hasFoldersToShow = Array.isArray(pageFolders) && pageFolders.length > 0;
  const hasActiveFilters = activeStatus !== 'all' || activeFolder !== 'all' || activeSort !== 'newest' || activeBuyer !== 'all' || Boolean(searchQuery);
  const shouldShowFolders = hasFoldersToShow && activeFolder !== 'all';
  const currentFolderName = activeFolder !== 'all' ? activeFolder : '';
  const keepQuery = `status=${encodeURIComponent(activeStatus)}&folder=${encodeURIComponent(activeFolder)}&sort=${encodeURIComponent(activeSort)}&buyer=${encodeURIComponent(activeBuyer)}&q=${encodeURIComponent(searchQuery)}`;
  const statusLabels = {
    planned: 'Planned',
    postponed: 'Postponed',
    bought: 'Bought',
    cancelled: 'Cancelled'
  };
  const statusIcons = {
    planned: 'bi-calendar-check',
    postponed: 'bi-pause-circle',
    bought: 'bi-check2-circle',
    cancelled: 'bi-x-circle'
  };

  const wishlistView = {
    formatMoney,
    activeStatus,
    activeFolder,
    activeSort,
    activeBuyer,
    searchQuery,
    hasFoldersToShow,
    hasActiveFilters,
    shouldShowFolders,
    currentFolderName,
    keepQuery,
    statusLabels,
    statusIcons,
    errorMessage: pageErrorMessage,
    successMessage: pageSuccessMessage,
    summary: pageSummary,
    folders: pageFolders,
    folderCards: pageFolderCards,
    folderStats: pageFolderStats,
    wishlistItems: pageWishlistItems,
    allWishlistItems: pageAllWishlistItems,
    familyMembers: pageFamilyMembers,
    currentUser: pageCurrentUser
  };
%>

<section class="container wishlist-shell">
  <%- include('./_flash', wishlistView) %>
  <%- include('../partials/page-overview', {
    eyebrow: 'Management',
    heading: 'Wishlist overview',
    description: 'Plan future purchases, sort them by folders and check how your planned spending affects the current budget.',
    buttonId: 'toggleWishlistCreateButton',
    buttonTextId: 'toggleWishlistCreateButtonText',
    controlsId: 'wishlistCreatePanel',
    buttonLabel: 'Add item',
    stats: [
      { value: formatMoney(pageSummary.balance), label: 'Current balance' },
      { value: formatMoney(pageSummary.plannedTotal), label: 'Planned spending' },
      { value: formatMoney(pageSummary.balanceAfterPlans), label: 'Balance after plans' },
      { value: pageSummary.totalItems, label: 'Wishlist items' }
    ],
    createContent: include('./_create_modal', wishlistView)
  }) %>
  <%- include('./_filters', wishlistView) %>
  <%- include('./_shared_modals', wishlistView) %>
  <%- include('./_cards', wishlistView) %>
</section>

<script src="/js/wishlist.js"></script>

<%- include('../partials/footer') %>