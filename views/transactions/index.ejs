<%- include('../partials/header') %>

<section class="container transactions-shell">
  <% if (errorMessage) { %>
    <div class="alert alert-danger rounded-3 mb-4" role="alert">
      <%= errorMessage %>
    </div>
  <% } %>

  <% if (successMessage) { %>
    <div class="alert alert-success rounded-3 mb-4" role="alert">
      <%= successMessage %>
    </div>
  <% } %>

  <%- include('../partials/page-overview', {
    eyebrow: 'Management',
    heading: 'Transaction overview',
    description: 'Track personal and family income or expenses in one clean workspace.',
    buttonId: 'toggleTransactionCreateButton',
    buttonTextId: 'toggleTransactionCreateButtonText',
    controlsId: 'transactionCreatePanel',
    buttonLabel: 'Add transaction',
    stats: [
      { value: summary.total, label: 'Total' },
      { value: summary.expenseCount, label: 'Expenses' },
      { value: summary.incomeCount, label: 'Income' },
      { value: family ? 'On' : 'Off', label: 'Family mode' }
    ],
    createContent: include('./_form_new', { categories, members, filters })
  }) %>

  <div class="transactions-history-zone" data-transactions-history-zone>
    <%- include('./_filters', { categories, members, filters }) %>
    <%- include('./_table', { transactions, categories, members, filters }) %>
  </div>
</section>

<script src="/js/transactions.js"></script>

<%- include('../partials/footer') %>
